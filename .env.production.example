# ============================================================
# .env.production.example
# Sunucuda bu dosyayı kopyalayıp ".env" olarak kaydedin:
#   cp .env.production.example .env
# Sonra gerçek değerleri doldurun.
# ============================================================

# --- PostgreSQL (Docker container adı "postgres") ---
POSTGRES_DB=hukuk_sitesi
POSTGRES_USER=hukuk_user
POSTGRES_PASSWORD=BURAYA_GUCLU_BIR_SIFRE_YAZIN

# Bu satırı değiştirmeyin — docker-compose otomatik oluşturur
# DATABASE_URL docker-compose.yml içinde otomatik set ediliyor

# --- NextAuth ---
# Üretmek için: openssl rand -base64 32
AUTH_SECRET=BURAYA_32_KARAKTER_RANDOM_STRING

# Sitenizin tam adresi (sonda / olmadan)
AUTH_URL=https://DOMAIN_ADI
NEXT_PUBLIC_SITE_URL=https://DOMAIN_ADI

# --- E-posta (Resend) ---
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- İletişim bilgileri ---
NEXT_PUBLIC_WHATSAPP_NUMBER=+905XXXXXXXXX

# Google Maps embed URL (Google Maps → Paylaş → Haritayı göm → src="..." kısmı)
NEXT_PUBLIC_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# --- DeepL (Çeviri scripti için) ---
# https://www.deepl.com/pro-api → ücretsiz 500k karakter/ay
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# --- Seed (İlk kurulumda admin kullanıcısı oluşturur) ---
# Güçlü bir şifre girin — production'da değiştirin!
SEED_ADMIN_PASSWORD=BURAYA_GUCLU_BIR_SIFRE_YAZIN
